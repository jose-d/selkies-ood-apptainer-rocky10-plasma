Bootstrap: localimage
From: rocky10-plasma-base.sif

%labels
    Author Selkies OOD Apptainer
    Description Rocky 10 KDE Plasma Selkies development/runtime layer for PixelFlux
    Layer selkies

%post
    set -eux
    SELKIES_REF="5686f6c4d20ed63a27e253bac00fb89ef99828c8"

    rm -rf /tmp/selkies-src

    git clone https://github.com/selkies-project/selkies.git /tmp/selkies-src
    cd /tmp/selkies-src
    git checkout -f "${SELKIES_REF}"

    python3 -m venv /opt/selkies-ood/venv
    /opt/selkies-ood/venv/bin/pip install --upgrade pip setuptools wheel
    /opt/selkies-ood/venv/bin/pip install /tmp/selkies-src
    /opt/selkies-ood/venv/bin/python - <<'PY_EOF'
from pathlib import Path
import selkies.input_handler

path = Path(selkies.input_handler.__file__).resolve()
text = path.read_text()
old = '''            self.xkb_keymap = self.xkb_ctx.keymap_new_from_names(
                rules="evdev", model="pc105", layout="us", variant="", options=""
            )
'''
new = '''            import os
            xkb_layout = os.environ.get("XKB_DEFAULT_LAYOUT", "us")
            xkb_variant = os.environ.get("XKB_DEFAULT_VARIANT", "")
            xkb_options = os.environ.get("XKB_DEFAULT_OPTIONS", "")
            self.xkb_keymap = self.xkb_ctx.keymap_new_from_names(
                rules="evdev", model="pc105", layout=xkb_layout, variant=xkb_variant, options=xkb_options
            )
            logger_webrtc_input.info(
                f"Built Wayland keymap from XKB layout={xkb_layout!r}, variant={xkb_variant!r}, options={xkb_options!r}."
            )
'''
if old not in text:
    raise SystemExit(f"Could not find hardcoded Selkies Wayland keymap block in {path}")
text = text.replace(old, new, 1)
text = text.replace(
    "logger_webrtc_input.warning(f\"Could not force 'us' layout, using default: {e}\")",
    'logger_webrtc_input.warning(f"Could not build configured XKB layout, using default: {e}")',
    1,
)
path.write_text(text)
print(f"Patched Selkies Wayland keymap layout handling in {path}")
PY_EOF
    /opt/selkies-ood/venv/bin/python - <<'PY_EOF'
from pathlib import Path
import py_compile
import selkies.input_handler

py_compile.compile(str(Path(selkies.input_handler.__file__).resolve()), doraise=True)
PY_EOF

    cd /tmp/selkies-src/addons/selkies-web-core
    npm install
    npm run build

    cd /tmp/selkies-src/addons/selkies-dashboard
    cp ../selkies-web-core/dist/selkies-core.js src/
    npm install
    export SELKIES_INJECT=1
    export SELKIES_MODE=websockets
    export SELKIES_UPLOAD_DIR='~/Desktop'
    npm run build
    mkdir -p dist/src dist/assets /opt/selkies-ood/web
    cp ../selkies-web-core/dist/selkies-core.js dist/src/
    cp ../selkies-web-core/dist/clipboard-worker* dist/assets/
    cp ../universal-touch-gamepad/universalTouchGamepad.js dist/src/
    cp -r ../selkies-web-core/dist/jsdb dist/ || true
    cp -a dist/. /opt/selkies-ood/web/

    cat > /opt/selkies-ood/web/manifest.json <<'MANIFEST_EOF'
{
  "name": "Selkies",
  "short_name": "Selkies",
  "manifest_version": 2,
  "version": "1.0.0",
  "display": "fullscreen",
  "background_color": "#000000",
  "theme_color": "#000000",
  "start_url": "/"
}
MANIFEST_EOF

    rm -rf /tmp/selkies-src /root/.cache /root/.npm
    dnf clean all

%environment
    export SELKIES_CODEC_PREFIX=/opt/selkies-codecs
    export SELKIES_WEB_ROOT=/opt/selkies-ood/web
    export GDK_BACKEND=wayland
    export QT_QPA_PLATFORM=wayland
    export XDG_SESSION_TYPE=wayland
    export LD_LIBRARY_PATH=/opt/selkies-codecs/lib64:$LD_LIBRARY_PATH
    export GST_PLUGIN_PATH=/opt/selkies-codecs/lib64/gstreamer-1.0:$GST_PLUGIN_PATH
    export PATH=/opt/selkies-ood/venv/bin:$PATH
