Bootstrap: docker
From: rockylinux/rockylinux:10

%labels
    Author Selkies OOD Apptainer
    Description Rocky 10 KDE Plasma base with static desktop dependencies and Selkies codecs
    Layer base

%post
    set -eux
    X264_REF="b35605ace3ddf7c1a5d67a2eb553f034aef41d55"
    GSTREAMER_REF="0c88a1af6b5ab19f9d2bc8dc725fec90b7fe5494"
    CODEC_PREFIX="/opt/selkies-codecs"

    dnf -y install epel-release || true
    /usr/bin/crb enable || true
    dnf -y install \
        bash-completion \
        ca-certificates \
        dbus-daemon \
        diffutils \
        dolphin \
        firefox \
        gcc \
        gcc-c++ \
        git \
        glib2-devel \
        gstreamer1 \
        gstreamer1-devel \
        gstreamer1-plugins-bad-free \
        gstreamer1-plugins-base \
        gstreamer1-plugins-base-devel \
        gstreamer1-plugins-good \
        gstreamer1-plugins-ugly-free \
        hostname \
        iproute \
        kscreen \
        kscreenlocker \
        kwin-wayland \
        libxkbcommon \
        libxkbcommon-devel \
        make \
        mesa-dri-drivers \
        mesa-libEGL \
        mesa-libgbm \
        meson \
        nasm \
        ninja-build \
        nodejs \
        npm \
        pkgconf-pkg-config \
        plasma-desktop \
        plasma-systemmonitor \
        plasma-workspace \
        procps-ng \
        python3 \
        python3-devel \
        python3-pip \
        which \
        wl-clipboard \
        xdg-desktop-portal-kde \
        xdg-user-dirs \
        xkeyboard-config \
        yasm \
        xorg-x11-server-Xwayland

    setcap -r /usr/bin/kwin_wayland 2>/dev/null || true

    export CFLAGS="-O2 -pipe -mtune=generic"
    export CXXFLAGS="-O2 -pipe -mtune=generic"

    rm -rf /tmp/x264-src /tmp/gstreamer-src

    git clone https://code.videolan.org/videolan/x264.git /tmp/x264-src
    cd /tmp/x264-src
    git checkout -f "${X264_REF}"
    ./configure \
        --prefix="${CODEC_PREFIX}" \
        --libdir="${CODEC_PREFIX}/lib64" \
        --enable-shared \
        --enable-pic \
        --disable-cli
    make -j"$(nproc)"
    make install

    git clone https://gitlab.freedesktop.org/gstreamer/gstreamer.git /tmp/gstreamer-src
    cd /tmp/gstreamer-src
    git checkout -f "${GSTREAMER_REF}"
    cd subprojects/gst-plugins-ugly
    export PKG_CONFIG_PATH="${CODEC_PREFIX}/lib64/pkgconfig:${PKG_CONFIG_PATH:-}"
    meson setup builddir \
        --prefix="${CODEC_PREFIX}" \
        --libdir=lib64 \
        --buildtype=release \
        -Dauto_features=disabled \
        -Dgpl=enabled \
        -Dx264=enabled \
        -Dtests=disabled
    ninja -C builddir
    ninja -C builddir install

    export LD_LIBRARY_PATH="${CODEC_PREFIX}/lib64:${LD_LIBRARY_PATH:-}"
    export GST_PLUGIN_PATH="${CODEC_PREFIX}/lib64/gstreamer-1.0:${GST_PLUGIN_PATH:-}"
    gst-inspect-1.0 x264enc

    rm -rf /tmp/x264-src /tmp/gstreamer-src /root/.cache
    dnf clean all

%environment
    export SELKIES_CODEC_PREFIX=/opt/selkies-codecs
    export GDK_BACKEND=wayland
    export QT_QPA_PLATFORM=wayland
    export XDG_SESSION_TYPE=wayland
    export LD_LIBRARY_PATH=/opt/selkies-codecs/lib64:$LD_LIBRARY_PATH
    export GST_PLUGIN_PATH=/opt/selkies-codecs/lib64/gstreamer-1.0:$GST_PLUGIN_PATH
